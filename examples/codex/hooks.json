{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Read|NotebookRead|Grep|Glob|Bash|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "./bin/agent-guard hook-pre-tool",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Read|NotebookRead|Grep|Glob|Bash|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "./bin/agent-guard hook-post-tool",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./bin/agent-guard hook-stop",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
